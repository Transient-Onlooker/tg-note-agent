# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=

# NVIDIA NIM
NIM_API_KEY=
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_ROUTER_MODEL=nvidia/nemotron-3-nano-30b-a3b
NIM_TEXT_MODEL=meta/llama-3.3-70b-instruct
NIM_ROUTER_TIMEOUT_SECONDS=12
NIM_TEXT_TIMEOUT_SECONDS=45
NIM_TIMEOUT_SECONDS=30
NIM_MAX_TOKENS=900000
NIM_VISION_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning

# Optional Notion
NOTION_API_KEY=
NOTION_NOTES_DATABASE_ID=
NOTION_PARENT_PAGE_ID=
NOTION_TITLE_PROPERTY=Name
NOTION_TAGS_PROPERTY=
NOTION_TIMEOUT_SECONDS=15

# Storage
SQLITE_PATH=/data/app.sqlite
IMAGE_ROOT=/images
