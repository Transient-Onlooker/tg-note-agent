flowchart TD
    In["Telegram message / photo"] --> Store["Store MESSAGE immediately"]
    Store --> Ack["Reply: 수신 완료."]
    Store --> Context["Load same-chat context<br/>last 30 minutes only"]
    Context --> Decide["Hybrid routing"]

    Decide --> Fast{"Common request?"}
    Fast -->|Yes| FastTool["Fast-path tool route"]
    Fast -->|No| Agent["Read-focused fallback agent"]

    FastTool --> Count["count_notes"]
    FastTool --> Search["search_notes"]
    FastTool --> Tags["list_tags / notes_by_tag"]
    FastTool --> MergeSuggest["suggest_note_merge"]

    Agent --> Read1["search_notes / list_tags / recent_notes"]
    Read1 --> Read2["read_note if needed"]
    Read2 --> Respond["Final plain text response"]

    Decide --> Note{"Should save note?"}
    Note -->|Create| Create["Create NOTE"]
    Note -->|Append| Append["Append to existing NOTE"]
    Note -->|Ignore| Ignore["Do not save"]

    Decide --> Photo{"Photo?"}
    Photo -->|Note image| OCR["OCR + classify + save"]
    Photo -->|Unclear| Clarify["Ask user"]
    Photo -->|General photo| Archive["Keep archive only"]

    MergeSuggest --> Proposal["Create MERGE_PROPOSAL"]
    Proposal --> Approve{"User approves?"}
    Approve -->|Yes| MergeExec["Merge note and delete duplicate"]
    Approve -->|No| Close["Close proposal"]

    Count --> Done["Reply to user"]
    Search --> Done
    Tags --> Done
    Respond --> Done
    Create --> Done
    Append --> Done
    Ignore --> Done
    OCR --> Done
    Clarify --> Done
    Archive --> Done
    MergeExec --> Done
    Close --> Done
